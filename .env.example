# Server
PORT=3000
NODE_ENV=development

# Auth - JWT_SECRET must match across all EGO Services apps
JWT_SECRET=replace_with_32+_random_chars
SESSION_SECRET=replace_with_another_secret
INTERNAL_AUTH_SECRET=replace_with_internal_service_secret
JWT_EXPIRES_IN=8h

# Users: comma-separated username:bcrypt_hash pairs
# Generate hash: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
USERS=alice:$2b$10$HASH_HERE,bob:$2b$10$HASH_HERE

# Data
DATA_DIR=./data
